# Root-device path: make these built in, or guarantee them in the initramfs.
CONFIG_SCSI=y
CONFIG_BLK_DEV_SD=y
CONFIG_USB=y
CONFIG_USB_XHCI_HCD=y
CONFIG_USB_XHCI_PCI=y
CONFIG_USB_STORAGE=y
CONFIG_XFS_FS=y
CONFIG_EFI_PARTITION=y
CONFIG_DEVTMPFS=y

# Required when any boot-critical driver is carried in an initramfs.
CONFIG_BLK_DEV_INITRD=y

# Preserve USB devices across system sleep when possible.
CONFIG_USB_DEFAULT_PERSIST=y

# Suspend support used by the validated setup.
CONFIG_PM=y
CONFIG_PM_SLEEP=y
CONFIG_SUSPEND=y
